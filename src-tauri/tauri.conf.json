{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OxideMD",
"version": "2.0.0",
  "identifier": "com.oxidemd.viewer",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "OxideMD",
        "width": 600,
        "height": 700,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis", "deb", "rpm", "appimage", "app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkd"],
        "mimeType": "text/markdown",
        "name": "Markdown File",
        "description": "Markdown Document"
      }
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "oxidemd.desktop"
      }
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/FenrirTheGray/OxideMD/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERBMzIyNkY2REFDMDU5OTcKUldTWFdjRGE5aVl5MmtweXhrc2xFV2pWekE4eWpHVS83Tm8rMFhpT1VDRzZCK1Jpd1NybHp4QkIK"
    }
  }
}
